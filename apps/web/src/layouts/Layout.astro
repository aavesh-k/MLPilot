---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
}

const { title = 'MLPilot' } = Astro.props;
---

<!doctype html>
<html lang="en" class="[color-scheme:light] dark:[color-scheme:dark]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme:light)" />
    <meta name="theme-color" content="#111318" media="(prefers-color-scheme:dark)" />
    <ClientRouter />
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem("theme");
          var dark = t ? t === "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased [font-variant-numeric:proportional-nums]">
    <slot />
  </body>
</html>
