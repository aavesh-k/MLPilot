---
import Layout from "./Layout.astro";
import Navbar from "@/components/Navbar.astro";

interface Props {
  title?: string;
  container?: boolean;
}

const { title = "AutoML Studio", container = true } = Astro.props;
---

<Layout title={title}>
  <Navbar />
  <main class={container ? "mx-auto w-full max-w-6xl px-4 py-8" : ""}>
    <slot />
  </main>
</Layout>
