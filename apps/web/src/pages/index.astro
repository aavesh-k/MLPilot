---
import AppLayout from "../layouts/AppLayout.astro";
import HeroParallax from "@/components/HeroParallax";
import { buttonVariants } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";

const features = [
  {
    title: "Drop a CSV, get a model",
    desc: "Upload any structured dataset. We handle validation, profiling, and preview \u2014 no configuration needed.",
    metric: "3 seconds",
    metricLabel: "to profile",
  },
  {
    title: "Auto-detect task type",
    desc: "Classification or regression? We detect it from your target column and select the right evaluation metrics.",
    metric: "9 models",
    metricLabel: "classification roster",
  },
  {
    title: "Compare every candidate",
    desc: "Cross-validated scores, permutation importance, and plain-language insights \u2014 ranked and explained.",
    metric: "5-fold CV",
    metricLabel: "on every model",
  },
  {
    title: "Export in one click",
    desc: "Download the best model, predictions, cleaned data, a Markdown report, or a formatted PDF.",
    metric: "5 formats",
    metricLabel: "model, CSV, MD, PDF",
  },
];

const howItWorks = [
  {
    title: "Upload",
    desc: "Drag a CSV onto the drop zone. We validate, parse, and return a 50-row preview with column types and null counts.",
  },
  {
    title: "Profile",
    desc: "Statistical summary \u2014 distributions, correlations, class balance, suggested target, and problem type.",
  },
  {
    title: "Train",
    desc: "A roster of 9 classifiers or 8 regressors is trained with cross-validation. Progress streams live via SSE.",
  },
  {
    title: "Export",
    desc: "Review charts, a ranked leaderboard, feature importance, and insights. Download what you need.",
  },
];
---

<AppLayout title="MLPilot \u2014 Automated Machine Learning" container={false}>
  <!-- Hero -->
  <HeroParallax client:load>
    <section class="mx-auto max-w-6xl px-4 sm:px-6 py-20 sm:py-28 lg:py-36">
      <div class="flex flex-col items-center text-center gap-6 max-w-3xl mx-auto">
        <Badge variant="secondary" class="animate-in fade-in slide-in-from-bottom-2 press">
          Automated Machine Learning
        </Badge>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.08] tracking-[-0.03em] text-balance animate-in fade-in slide-in-from-bottom-3">
          From raw CSV to{" "}
          <span class="text-primary">compared, explained models</span>
          {" "}in one flow.
        </h1>
        <p class="text-lg sm:text-xl text-muted-foreground max-w-2xl text-balance animate-in fade-in slide-in-from-bottom-4">
          Upload a dataset, pick a target, and let MLPilot handle training,
          comparison, and explanation. No pipelines to wire, no boilerplate to maintain.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 animate-in fade-in slide-in-from-bottom-5">
          <a href="/dashboard" class={buttonVariants({ size: "lg" })}>
            Start a run &rarr;
          </a>
          <a href="/reports" class={buttonVariants({ variant: "outline", size: "lg" })}>
            View reports
          </a>
        </div>
      </div>
    </section>
  </HeroParallax>

  <!-- Feature sections -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="grid gap-16">
      {features.map((f, i) => (
        <div
          class={`reveal grid gap-8 items-center sm:grid-cols-2 ${i % 2 === 1 ? "sm:[&>*:first-child]:order-2" : ""}`}
        >
          <div class="space-y-3">
            <Badge variant="secondary" class="capitalize">0{i + 1}</Badge>
            <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">{f.title}</h2>
            <p class="text-muted-foreground text-pretty max-w-lg">{f.desc}</p>
          </div>
          <div class="surface-raised p-6 sm:p-8 text-center">
            <p class="text-4xl sm:text-5xl font-bold text-primary tabular-nums">{f.metric}</p>
            <p class="mt-1 text-sm text-muted-foreground">{f.metricLabel}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-border bg-accent/30">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20 sm:py-28">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">How it works</h2>
        <p class="mt-2 text-muted-foreground">Four steps from upload to export.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 stagger">
        {howItWorks.map((step, i) => (
          <div key={step.title} class="surface-raised p-5 space-y-3 relative">
            <span class="flex size-8 items-center justify-center rounded-full bg-primary/10 text-primary text-sm font-semibold tabular-nums">
              {i + 1}
            </span>
            <h3 class="font-semibold">{step.title}</h3>
            <p class="text-sm text-muted-foreground text-pretty">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-20 sm:py-28 text-center">
    <div class="surface-raised p-10 sm:p-14 max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">Ready to automate your workflow?</h2>
      <p class="mt-3 text-muted-foreground max-w-md mx-auto text-pretty">
        Upload a dataset and see the full pipeline in action \u2014 profiling, training, comparison, and export.
      </p>
      <a href="/dashboard" class={`${buttonVariants({ size: "lg" })} mt-6`}>
        Start a run &rarr;
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-4 sm:px-6 py-8 text-sm text-muted-foreground sm:flex-row">
      <p>&copy; {new Date().getFullYear()} MLPilot. Automated machine learning.</p>
      <div class="flex gap-5">
        <a href="/dashboard" class="hover:text-foreground transition-colors">Dashboard</a>
        <a href="/reports" class="hover:text-foreground transition-colors">Reports</a>
        <a href="/settings" class="hover:text-foreground transition-colors">Settings</a>
      </div>
    </div>
  </footer>
</AppLayout>
