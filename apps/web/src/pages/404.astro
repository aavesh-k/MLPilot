---
import AppLayout from "../layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
---

<AppLayout title="Not found — AutoML Studio" container={false}>
  <div class="mx-auto flex min-h-[70vh] max-w-md flex-col items-center justify-center gap-4 px-4 text-center">
    <p class="text-6xl font-bold tracking-tight text-primary">404</p>
    <h1 class="text-2xl font-semibold">Page not found</h1>
    <p class="text-muted-foreground">The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class={buttonVariants({ size: "lg" })}>Back to home</a>
  </div>
</AppLayout>
