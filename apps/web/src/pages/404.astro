---
import AppLayout from "../layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
---

<AppLayout title="Not found — MLPilot" container={false}>
  <div class="mx-auto flex min-h-[calc(100dvh-14rem)] max-w-md flex-col items-center justify-center gap-5 px-4 text-center">
    <p class="text-7xl font-bold tracking-tight text-primary tabular-nums">404</p>
    <h1>Page not found</h1>
    <p class="text-muted-foreground">The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class={buttonVariants({ size: "lg" })}>Back to home</a>
  </div>
</AppLayout>
