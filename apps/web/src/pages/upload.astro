---
import AppLayout from "../layouts/AppLayout.astro";
import DatasetUploader from "../islands/DatasetUploader";
import { Badge } from "@/components/ui/badge";
---

<AppLayout title="Upload Dataset — AutoML Studio">
  <div class="mx-auto max-w-3xl">
    <div class="space-y-2">
      <Badge variant="secondary">Step 1 of 2</Badge>
      <h1 class="text-3xl font-bold tracking-tight">Upload your dataset</h1>
      <p class="text-muted-foreground">
        Drop a CSV below. We validate it, profile the columns and types, then you pick a target
        and we train and compare real models automatically.
      </p>
    </div>
    <div class="mt-8">
      <DatasetUploader client:load />
    </div>
  </div>
</AppLayout>
